generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum PlatformRole {
  user
  platform_admin
}

enum BlogStatus {
  draft
  published
  scheduled
  archived
  publish_failed
}

enum ArticleType {
  engineering_blog
  architecture_deep_dive
  case_study
  scaling_story
  failure_postmortem
  ai_experiment
  founder_note
  tutorial
  opinion_essay
  project_showcase
  open_source_release
  other
}

enum CompanyRole {
  owner
  author
}

enum MilestoneType {
  launch
  user_milestone
  infra_update
  funding
  feature_release
  bug_fixed
  partnership
  hiring
  experiment
  other
}

enum InviteStatus {
  pending
  accepted
  declined
  expired
}

enum IndustryType {
  ai
  saas
  dev_tools
  fintech
  health_tech
  ed_tech
  consumer
  other
}

enum CompanyStage {
  idea
  mvp_stage
  early_stage
  growth
  scale
}

enum EntityType {
  blog
  company
  author
  tag
}

// ─── Identity & Auth ──────────────────────────────────────────────────────────

model User {
  id                String       @id @default(uuid()) @db.Uuid
  email             String       @unique @db.VarChar(320)
  password          String?
  provider          AuthProvider @default(LOCAL)
  providerId        String?
  isEmailVerified   Boolean      @default(false)
  isActive          Boolean      @default(true)
  platformRole      PlatformRole @default(user)
  passwordChangedAt DateTime?
  deletedAt         DateTime?
  createdAt         DateTime     @default(now())

  authorProfile      AuthorProfile?
  refreshTokens      RefreshToken[]
  passwordResets     PasswordResetToken[]
  emailVerifications EmailVerificationToken[]
  authAuditLogs      AuthAuditLog[]
  companyMemberships CompanyMembership[]
  companyInvitesSent CompanyInvite[]          @relation("invitedBy")
  blogs              Blog[]
  companiesCreated   Company[]                @relation("companyCreator")
  milestones         CompanyMilestone[]
  authorFollows      AuthorFollow[]
  companyFollows     CompanyFollow[]
  tagFollows         TagFollow[]
  blogViews          BlogView[]
  blogLikes          BlogLike[]
  blogSaves          BlogSave[]
  blogShares         BlogShare[]
  readSessions       BlogReadSession[]
  notifications      Notification[]

  @@map("users")
}

model AuthorProfile {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @unique @db.Uuid
  displayName   String   @db.VarChar(100)
  username      String   @unique @db.VarChar(50)
  bio           String?  @db.VarChar(300)
  avatarUrl     String?
  expertiseTags String[]
  twitterHandle String?  @db.VarChar(100)
  linkedinUrl   String?
  githubHandle  String?  @db.VarChar(100)
  websiteUrl    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  followers     AuthorFollow[]

  @@map("author_profiles")
}

// ─── Auth Support Tables ──────────────────────────────────────────────────────

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  tokenHash  String    @unique
  userId     String    @db.Uuid
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedBy String?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique
  userId    String    @db.Uuid
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique
  userId    String    @db.Uuid
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model LoginAttempt {
  id             String    @id @default(uuid()) @db.Uuid
  identifierHash String    @unique
  ipAddress      String?
  failedCount    Int       @default(0)
  lockedUntil    DateTime?
  lastFailedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([lockedUntil])
  @@map("login_attempts")
}

model AuthAuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  event     String
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([event])
  @@index([createdAt])
  @@map("auth_audit_logs")
}

// ─── Company Domain ───────────────────────────────────────────────────────────

model Company {
  id                String        @id @default(uuid()) @db.Uuid
  createdByUserId   String        @db.Uuid
  name              String        @db.VarChar(100)
  handle            String        @unique @db.VarChar(50)
  tagline           String        @db.VarChar(160)
  websiteUrl        String?
  logoUrl           String?
  coverImageUrl     String?
  industry          IndustryType?
  stage             CompanyStage?
  techStack         String[]
  founderSocialLink String?
  isPublic          Boolean       @default(true)
  featured          Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  creator     User                @relation("companyCreator", fields: [createdByUserId], references: [id])
  memberships CompanyMembership[]
  invites     CompanyInvite[]
  blogs       Blog[]
  milestones  CompanyMilestone[]
  followers   CompanyFollow[]

  @@index([handle])
  @@index([featured])
  @@map("companies")
}

model CompanyMembership {
  id        String      @id @default(uuid()) @db.Uuid
  companyId String      @db.Uuid
  userId    String      @db.Uuid
  role      CompanyRole
  joinedAt  DateTime    @default(now())
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId], name: "uq_company_memberships_company_user")
  @@index([companyId], name: "idx_company_memberships_company")
  @@index([userId], name: "idx_company_memberships_user")
  @@map("company_memberships")
}

model CompanyInvite {
  id              String       @id @default(uuid()) @db.Uuid
  companyId       String       @db.Uuid
  invitedByUserId String       @db.Uuid
  invitedEmail    String       @db.VarChar(320)
  status          InviteStatus @default(pending)
  token           String       @unique
  expiresAt       DateTime
  acceptedAt      DateTime?
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedBy       User         @relation("invitedBy", fields: [invitedByUserId], references: [id])

  @@index([companyId], name: "idx_company_invites_company")
  @@index([token], name: "idx_company_invites_token")
  @@index([companyId, invitedEmail], name: "idx_company_invites_company_email")
  @@map("company_invites")
}

// ─── Content Domain ───────────────────────────────────────────────────────────

model Blog {
  id                String      @id @default(uuid()) @db.Uuid
  authorId          String      @db.Uuid
  companyId         String?     @db.Uuid
  title             String      @db.VarChar(150)
  slug              String      @unique @db.VarChar(200)
  body              String
  summary           String?     @db.VarChar(300)
  coverImageUrl     String?
  ogImageUrl        String
  articleType       ArticleType
  status            BlogStatus  @default(draft)
  publishedAt       DateTime?
  scheduledAt       DateTime?
  scheduledTimezone String?     @db.VarChar(100)
  seoTitleOverride   String?     @db.VarChar(60)
  seoDescOverride    String?     @db.VarChar(160)
  readingTimeMinutes Int?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  author             User                    @relation(fields: [authorId], references: [id])
  company            Company?                @relation(fields: [companyId], references: [id])
  tags               BlogTag[]
  views              BlogView[]
  likes              BlogLike[]
  saves              BlogSave[]
  shares             BlogShare[]
  readSessions       BlogReadSession[]
  engagementCounters BlogEngagementCounters?

  @@index([authorId], name: "idx_blogs_author")
  @@index([companyId], name: "idx_blogs_company")
  @@index([status], name: "idx_blogs_status")
  @@index([status, scheduledAt], name: "idx_blogs_scheduled")
  @@index([authorId, status], name: "idx_blogs_author_status")
  @@index([companyId, status], name: "idx_blogs_company_status")
  @@map("blogs")
}

model BlogTag {
  blogId String @db.Uuid
  tagId  String @db.Uuid
  blog   Blog   @relation(fields: [blogId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([blogId, tagId], name: "pk_blog_tags")
  @@index([tagId], name: "idx_blog_tags_tag")
  @@map("blog_tags")
}

model Tag {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique @db.VarChar(50)
  slug        String    @unique @db.VarChar(60)
  description String?
  blogCount   Int        @default(0)
  isApproved  Boolean    @default(false)
  createdAt   DateTime   @default(now())
  blogs       BlogTag[]
  followers   TagFollow[]

  @@index([isApproved], name: "idx_tags_approved")
  @@map("tags")
}

// ─── Build-In-Public Timeline ─────────────────────────────────────────────────

model CompanyMilestone {
  id              String        @id @default(uuid()) @db.Uuid
  companyId       String        @db.Uuid
  createdByUserId String        @db.Uuid
  type            MilestoneType
  headline        String        @db.VarChar(100)
  description     String?       @db.VarChar(500)
  impactMetric    String?       @db.VarChar(80)
  milestoneDate   DateTime      @db.Date
  createdAt       DateTime      @default(now())

  company       Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUser User    @relation(fields: [createdByUserId], references: [id])

  @@index([companyId], name: "idx_milestones_company")
  @@index([companyId, milestoneDate], name: "idx_milestones_company_date")
  @@map("company_milestones")
}

// ─── SEO & Routing ────────────────────────────────────────────────────────────

model SeoMetadata {
  id              String     @id @default(uuid()) @db.Uuid
  entityId        String     @db.Uuid
  entityType      EntityType
  metaTitle       String     @db.VarChar(60)
  metaDescription String     @db.VarChar(160)
  ogImageUrl      String
  canonicalUrl    String
  schemaJson      String
  lastGeneratedAt DateTime   @default(now())

  @@unique([entityId, entityType], name: "uq_seo_metadata_entity")
  @@index([entityType], name: "idx_seo_metadata_type")
  @@map("seo_metadata")
}

model SlugRedirect {
  id         String     @id @default(uuid()) @db.Uuid
  fromSlug   String     @db.VarChar(200)
  toSlug     String     @db.VarChar(200)
  entityType EntityType
  createdAt  DateTime   @default(now())

  @@unique([fromSlug, entityType], name: "uq_slug_redirects_from_type")
  @@index([entityType], name: "idx_slug_redirects_type")
  @@map("slug_redirects")
}

// ─── Social Graph ─────────────────────────────────────────────────────────────

model AuthorFollow {
  id              String        @id @default(uuid()) @db.Uuid
  followerId      String        @db.Uuid
  authorProfileId String        @db.Uuid
  createdAt       DateTime      @default(now())
  follower        User          @relation(fields: [followerId], references: [id], onDelete: Cascade)
  authorProfile   AuthorProfile @relation(fields: [authorProfileId], references: [id], onDelete: Cascade)

  @@unique([followerId, authorProfileId], name: "uq_author_follows_follower_author")
  @@index([authorProfileId], name: "idx_author_follows_author")
  @@map("author_follows")
}

model CompanyFollow {
  id         String   @id @default(uuid()) @db.Uuid
  followerId String   @db.Uuid
  companyId  String   @db.Uuid
  createdAt  DateTime @default(now())
  follower   User     @relation(fields: [followerId], references: [id], onDelete: Cascade)
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([followerId, companyId], name: "uq_company_follows_follower_company")
  @@index([companyId], name: "idx_company_follows_company")
  @@map("company_follows")
}

model TagFollow {
  id         String   @id @default(uuid()) @db.Uuid
  followerId String   @db.Uuid
  tagId      String   @db.Uuid
  createdAt  DateTime @default(now())
  follower   User     @relation(fields: [followerId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([followerId, tagId], name: "uq_tag_follows_follower_tag")
  @@index([tagId], name: "idx_tag_follows_tag")
  @@map("tag_follows")
}

// ─── Analytics & Telemetry ────────────────────────────────────────────────────

model BlogView {
  id        String   @id @default(uuid()) @db.Uuid
  blogId    String   @db.Uuid
  viewerId  String?  @db.Uuid
  ipHash    String?  @db.VarChar(64)
  sessionId String?  @db.VarChar(64)
  source    String?  @db.VarChar(50)
  referrer  String?
  device    String?  @db.VarChar(20)
  viewedAt  DateTime @default(now())
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  viewer    User?    @relation(fields: [viewerId], references: [id], onDelete: SetNull)

  @@index([blogId], name: "idx_blog_views_blog")
  @@index([blogId, viewedAt], name: "idx_blog_views_blog_date")
  @@map("blog_views")
}

model BlogLike {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  blogId    String   @db.Uuid
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@unique([userId, blogId], name: "uq_blog_likes_user_blog")
  @@index([blogId], name: "idx_blog_likes_blog")
  @@map("blog_likes")
}

model BlogSave {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  blogId    String   @db.Uuid
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@unique([userId, blogId], name: "uq_blog_saves_user_blog")
  @@index([blogId], name: "idx_blog_saves_blog")
  @@map("blog_saves")
}

model BlogShare {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  blogId    String   @db.Uuid
  channel   String?  @db.VarChar(50)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@index([blogId], name: "idx_blog_shares_blog")
  @@map("blog_shares")
}

model BlogReadSession {
  id                  String   @id @default(uuid()) @db.Uuid
  blogId              String   @db.Uuid
  userId              String?  @db.Uuid
  sessionId           String   @db.VarChar(64)
  maxScrollDepth      Int      @default(0)
  readDurationSeconds Int      @default(0)
  completed           Boolean  @default(false)
  startedAt           DateTime @default(now())
  lastEventAt         DateTime @default(now())
  blog                Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  user                User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([blogId, sessionId], name: "uq_read_session_blog_session")
  @@index([blogId], name: "idx_read_sessions_blog")
  @@index([userId], name: "idx_read_sessions_user")
  @@map("blog_read_sessions")
}

// Materialized counter cache — never written by user-facing endpoints, only by cron aggregation.
model BlogEngagementCounters {
  blogId            String   @id @db.Uuid
  totalViews        Int      @default(0)
  uniqueViews       Int      @default(0)
  likes             Int      @default(0)
  saves             Int      @default(0)
  shares            Int      @default(0)
  avgCompletionRate Float    @default(0)
  trendingScore     Float    @default(0)
  updatedAt         DateTime @default(now()) @updatedAt
  blog              Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@map("blog_engagement_counters")
}

// ─── Notifications ────────────────────────────────────────────────────────────

enum NotificationType {
  follow
  company_invite
  blog_published
}

model Notification {
  id         String           @id @default(uuid()) @db.Uuid
  userId     String           @db.Uuid
  type       NotificationType
  message    String           @db.VarChar(300)
  isRead     Boolean          @default(false)
  metadata   Json?
  createdAt  DateTime         @default(now())
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead], name: "idx_notifications_user_read")
  @@index([userId, createdAt], name: "idx_notifications_user_date")
  @@map("notifications")
}
